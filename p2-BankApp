import java.util.*;

class BankAccount {

    String name;
    String acctype;
    double balance;
    static int totalaccount = 0;

    // Constructor 1
    BankAccount(String name) {
        this.name = name;
        this.balance = 0;
        this.acctype = "Savings";
        totalaccount++;
    }

    // Constructor 2
    BankAccount(String name, double initdepo) {
        this.name = name;
        this.balance = initdepo;
        this.acctype = "Savings";
        totalaccount++;
    }

    // Constructor 3
    BankAccount(String name, double initdepo, String acctype) {
        this.name = name;
        this.balance = initdepo;
        this.acctype = acctype;
        totalaccount++;
    }

    // Deposit method (amount only)
    void deposit(double amount) {
        balance = balance + amount;
        System.out.println("Deposited: " + amount);
    }

    // Deposit method (amount + type)
    void deposit(double amount, String type) {
        balance = balance + amount;
        System.out.println("Deposited: " + amount + " via " + type);
    }

    // Withdraw method
    void withdraw(double amount) {
        if (balance - amount < 1000) {
            System.out.println("Withdraw not possible (minimum balance must be 1000)");
        } else {
            balance = balance - amount;
            System.out.println("Withdraw " + amount + " successfully");
        }
    }

    // Display account details
    void display() {
        System.out.println("--- Account Details ---");
        System.out.println("Name: " + name);
        System.out.println("Balance: " + balance);
        System.out.println("Account Type: " + acctype);
    }

    // Show total accounts
    static void showTotalAcc() {
        System.out.println("Total account created: " + totalaccount);
    }
}

public class BankApp {

    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);

        System.out.println("Enter name:");
        String name = sc.next();

        BankAccount acc = new BankAccount(name);

        while (true) {

            System.out.println("\nBank Menu");
            System.out.println("1. Deposit (Amount only)");
            System.out.println("2. Deposit (Amount + Type)");
            System.out.println("3. Withdraw");
            System.out.println("4. Account Details");
            System.out.println("5. Total Accounts");
            System.out.println("6. Exit");

            System.out.print("Enter choice: ");
            int c = sc.nextInt();

            switch (c) {

                case 1:
                    System.out.print("Enter deposit amount: ");
                    double d = sc.nextDouble();
                    acc.deposit(d);
                    break;

                case 2:
                    System.out.print("Enter deposit amount: ");
                    double amt = sc.nextDouble();
                    System.out.print("Enter transaction type (cash/cheque): ");
                    String type = sc.next();
                    acc.deposit(amt, type);
                    break;

                case 3:
                    System.out.print("Enter withdraw amount: ");
                    double w = sc.nextDouble();
                    acc.withdraw(w);
                    break;

                case 4:
                    acc.display();
                    break;

                case 5:
                    BankAccount.showTotalAcc();
                    break;

                case 6:
                    System.exit(0);
                    break;

                default:
                    System.out.println("Invalid choice");
            }
        }
    }
}
